# .env.docker
# Docker 本地部署的环境变量配置

# PostgreSQL 配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=7997
POSTGRES_DB=nest-demo

# Prisma 数据库连接字符串
# 重要：主机名是 postgres（docker-compose 里的服务名）
# 不是 localhost！容器之间通过服务名通信
DATABASE_URL="postgresql://postgres:7997@postgres:5432/nest-demo?schema=public"

# NestJS 配置
NODE_ENV=production
PORT=3000